    <Page x:Class="MusicSchoolWpf.Tuner"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Tuner">

    <Grid Background="#1E1E1E">

        <!-- תצוגת תדר -->
        <TextBlock x:Name="FrequencyText"
                   Text="110 Hz"
                   FontSize="36"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,0"/>

        <!-- בר כיוון -->
        <Grid Margin="40,100,40,0"
              Height="30"
              VerticalAlignment="Top">

            <Border Background="DarkRed"
                    CornerRadius="15"/>

            <Border Width="80"
                    Background="LimeGreen"
                    HorizontalAlignment="Center"
                    CornerRadius="10"/>

            <Rectangle Width="4"
                       Fill="White"
                       HorizontalAlignment="Center"/>
        </Grid>

        <!-- כפתור החלפה חשמלית/אקוסטית -->
        <Button Content="Switch Electric / Acoustic"
                Width="220"
                Height="35"
                VerticalAlignment="Top"
                Margin="0,160,0,0"
                Click="SwitchHead_Click"/>

        <!-- כפתור ימין/שמאל -->
        <ToggleButton x:Name="HandSwitch"
                      Width="150"
                      Height="35"
                      Content="Right Handed"
                      VerticalAlignment="Top"
                      Margin="0,210,0,0"
                      Checked="HandSwitch_Checked"
                      Unchecked="HandSwitch_Unchecked"/>

        <!-- ================= ELECTRIC RIGHT ================= -->
        <Canvas x:Name="ElectricRight"
                Width="300"
                Height="300"
                Margin="0,260,0,0">

            <Polygon Points="50,0 200,40 250,260 80,260"
                     Fill="#3A3A3A"/>

            <!-- 6 מפתחות בצד ימין -->
            <Ellipse Width="25" Height="25" Fill="Silver"
                     Canvas.Left="210" Canvas.Top="20"/>
            <Ellipse Width="25" Height="25" Fill="Silver"
                     Canvas.Left="220" Canvas.Top="60"/>
            <Ellipse Width="25" Height="25" Fill="Silver"
                     Canvas.Left="225" Canvas.Top="100"/>
            <Ellipse Width="25" Height="25" Fill="Silver"
                     Canvas.Left="225" Canvas.Top="140"/>
            <Ellipse Width="25" Height="25" Fill="Silver"
                     Canvas.Left="220" Canvas.Top="180"/>
            <Ellipse Width="25" Height="25" Fill="Silver"
                     Canvas.Left="210" Canvas.Top="220"/>
        </Canvas>

        <!-- ================= ELECTRIC LEFT ================= -->
        <Canvas x:Name="ElectricLeft"
                Width="300"
                Height="300"
                Margin="0,260,0,0"
                Visibility="Collapsed">

            <Polygon Points="250,0 100,40 50,260 220,260"
                     Fill="#3A3A3A"/>

            <!-- 6 מפתחות בצד שמאל -->
            <Ellipse Width="25" Height="25" Fill="Silver"
                     Canvas.Left="60" Canvas.Top="20"/>
            <Ellipse Width="25" Height="25" Fill="Silver"
                     Canvas.Left="50" Canvas.Top="60"/>
            <Ellipse Width="25" Height="25" Fill="Silver"
                     Canvas.Left="45" Canvas.Top="100"/>
            <Ellipse Width="25" Height="25" Fill="Silver"
                     Canvas.Left="45" Canvas.Top="140"/>
            <Ellipse Width="25" Height="25" Fill="Silver"
                     Canvas.Left="50" Canvas.Top="180"/>
            <Ellipse Width="25" Height="25" Fill="Silver"
                     Canvas.Left="60" Canvas.Top="220"/>
        </Canvas>

        <!-- ================= ACOUSTIC RIGHT ================= -->
        <Canvas x:Name="AcousticRight"
                Width="300"
                Height="300"
                Margin="0,260,0,0"
                Visibility="Collapsed">

            <Rectangle Width="120"
                       Height="260"
                       Fill="#8B5A2B"
                       Canvas.Left="90"/>

            <Ellipse Width="25" Height="25" Fill="Goldenrod"
                     Canvas.Left="60" Canvas.Top="20"/>
            <Ellipse Width="25" Height="25" Fill="Goldenrod"
                     Canvas.Left="215" Canvas.Top="20"/>

            <Ellipse Width="25" Height="25" Fill="Goldenrod"
                     Canvas.Left="60" Canvas.Top="90"/>
            <Ellipse Width="25" Height="25" Fill="Goldenrod"
                     Canvas.Left="215" Canvas.Top="90"/>

            <Ellipse Width="25" Height="25" Fill="Goldenrod"
                     Canvas.Left="60" Canvas.Top="160"/>
            <Ellipse Width="25" Height="25" Fill="Goldenrod"
                     Canvas.Left="215" Canvas.Top="160"/>
        </Canvas>

        <!-- ================= ACOUSTIC LEFT ================= -->
        <Canvas x:Name="AcousticLeft"
                Width="300"
                Height="300"
                Margin="0,260,0,0"
                Visibility="Collapsed">

            <Rectangle Width="120"
                       Height="260"
                       Fill="#8B5A2B"
                       Canvas.Left="90"/>

            <Ellipse Width="25" Height="25" Fill="Goldenrod"
                     Canvas.Left="215" Canvas.Top="20"/>
            <Ellipse Width="25" Height="25" Fill="Goldenrod"
                     Canvas.Left="60" Canvas.Top="20"/>

            <Ellipse Width="25" Height="25" Fill="Goldenrod"
                     Canvas.Left="215" Canvas.Top="90"/>
            <Ellipse Width="25" Height="25" Fill="Goldenrod"
                     Canvas.Left="60" Canvas.Top="90"/>

            <Ellipse Width="25" Height="25" Fill="Goldenrod"
                     Canvas.Left="215" Canvas.Top="160"/>
            <Ellipse Width="25" Height="25" Fill="Goldenrod"
                     Canvas.Left="60" Canvas.Top="160"/>
        </Canvas>

    </Grid>
</Page>
