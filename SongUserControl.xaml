
    <UserControl x:Class="MusicSchoolWpf.SongUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicSchoolWpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="White">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="18*"/>
            <RowDefinition Height="6*"/>
            <RowDefinition Height="49*"/>
        </Grid.RowDefinitions>
        <TextBlock Name="namebox" FontSize="50" Grid.Row="0"/>
        <TextBlock x:Name="artistbox"  FontSize="20" Grid.Row="1" HorizontalAlignment="Left" Background="DarkRed"  Width="100" TextAlignment="Center" FontWeight="Bold" />
        <TextBlock x:Name="genrebox"  FontSize="20" Grid.Row="1" HorizontalAlignment="Center" Background="DarkRed"  Width="100" TextAlignment="Center" FontWeight="Bold"/>
        <TextBlock x:Name="diffbox"  FontSize="20" Grid.Row="1" HorizontalAlignment="Right" Background="DarkRed"  Width="100" TextAlignment="Center" FontWeight="Bold"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,27,-10,10" Grid.RowSpan="2">
         
            <WrapPanel Margin="10,10,10,10" x:Name="songData" />

        </StackPanel>
    </Grid>
</UserControl>
