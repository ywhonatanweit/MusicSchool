<UserControl x:Class="MusicSchoolWpf.SongUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicSchoolWpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="18*"/>
            <RowDefinition Height="6*"/>
            <RowDefinition Height="49*"/>
        </Grid.RowDefinitions>

        <Border CornerRadius="20" Background="Honeydew">
            <StackPanel>
                <TextBlock Name="namebox" FontSize="50" Grid.Row="0" Margin="3" MouseDown="ShowSongData"/>
            </StackPanel>
        </Border>
      
        

      
    </Grid>
</UserControl>
