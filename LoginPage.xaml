<Page x:Class="MusicSchoolWpf.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MusicSchoolWpf"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage"
      Background="White">

    <Grid >
        <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20*" />
                <ColumnDefinition Width="8*" />
                <!--<ColumnDefinition Width="1*" />-->
            
            </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="1"  x:Name="loginpannel" Visibility="Visible" >
                <StackPanel>
                    <TextBox x:Name="loginusername"
     Margin="0 0 0 20"
     VerticalContentAlignment="Bottom"
     materialDesign:HintAssist.Hint="Username"
     materialDesign:HintAssist.HelperText="Enter your username"
     materialDesign:TextFieldAssist.HasClearButton="True"
     Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                </StackPanel>

                <StackPanel>
                    <PasswordBox x:Name="loginpassword" 
     Margin="0 0 0 20"
     VerticalContentAlignment="Bottom"
                 Width="200"
     materialDesign:HintAssist.HelperText="Not bound password"
     materialDesign:HintAssist.Hint="Password"
     materialDesign:TextFieldAssist.HasClearButton="True"
     Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}" />
                </StackPanel>
            <Button x:Name="login" Background="DarkRed" Content="LOG IN" RenderTransformOrigin="0.522,1.432"  Margin="0 0 0 0" Click="Login"/>

            <TextBlock HorizontalAlignment="Center">
    <Run Text="Don't have an account already? " />
    <Hyperlink Foreground="DarkBlue"
               TextDecorations="Underline"
               Cursor="Hand"
               Click="SwitchToSignup">
        <Run Text="Sign up" />
    </Hyperlink>
            </TextBlock>

          

            <!--<Button x:Name="signuppage" Background="DarkRed" Content="SIGN UP" RenderTransformOrigin="0.522,1.432"  Margin="0 0 0 0" Click="Signuppage"/>-->


        </StackPanel>
        <StackPanel x:Name="signuppannel" Grid.Column="1" Grid.Row="1" Visibility="Collapsed" VerticalAlignment="Center">
            <TextBox x:Name="signupusername"
     Margin="0 0 0 20"
     VerticalContentAlignment="Bottom"
     materialDesign:HintAssist.Hint="Username"
     materialDesign:HintAssist.HelperText="Enter your username"
     materialDesign:TextFieldAssist.HasClearButton="True"
     Style="{StaticResource MaterialDesignOutlinedTextBox}" />
        <!--</StackPanel>

        <StackPanel>-->
            <PasswordBox x:Name="signuppassword" 
     Margin="0 0 0 20"
     VerticalContentAlignment="Bottom"
                 Width="200"
     materialDesign:HintAssist.HelperText="Not bound password"
     materialDesign:HintAssist.Hint="Password"
     materialDesign:TextFieldAssist.HasClearButton="True"
     Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}" />
    
        <Button x:Name="signup" Background="DarkRed" Content="SIGN UP" RenderTransformOrigin="0.522,1.432"  Margin="0,0, 0, 0" Click="newsignup" />

        <TextBlock HorizontalAlignment="Center">
    <Run Text="already registered? " />
    <Hyperlink Foreground="DarkBlue"
               TextDecorations="Underline"
               Cursor="Hand"
               Click="SwitchTologin">
        <Run Text="log in" />
    </Hyperlink>
        </TextBlock>
        </StackPanel>
    </Grid>
    
</Page>
