<Page x:Class="MusicSchoolWpf.HomePage"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:MusicSchoolWpf"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="900"
      Title="HomePage">

    <Grid Background="#080808">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="64"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#0A0A0A"
                BorderBrush="#141414" BorderThickness="0,0,1,0">
            <StackPanel HorizontalAlignment="Center" Margin="0,18,0,18">

                <!-- Avatar -->
                <Ellipse Width="38" Height="38" Margin="0,0,0,14"
                         Stroke="#CC2200" StrokeThickness="1.5">
                    <Ellipse.Fill>
                        <SolidColorBrush Color="#110808"/>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Nav: Home (active) -->
                <Border Width="38" Height="38" CornerRadius="9"
                        Background="#140A0A" Margin="0,4"
                        BorderBrush="#55CC2200" BorderThickness="0.5">
                    <materialDesign:PackIcon Kind="Home"
                        Foreground="#CC2200" Width="17" Height="17"
                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Nav: Songs -->
                <Border Width="38" Height="38" CornerRadius="9"
                        Background="#111111" Margin="0,4"
                        BorderBrush="Transparent" BorderThickness="0.5"
                        Cursor="Hand">
                    <materialDesign:PackIcon Kind="MusicNote"
                        Foreground="#2E2E2E" Width="17" Height="17"
                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Nav: Metronome -->
                <Border Width="38" Height="38" CornerRadius="9"
                        Background="#111111" Margin="0,4"
                        BorderBrush="Transparent" BorderThickness="0.5"
                        Cursor="Hand">
                    <materialDesign:PackIcon Kind="Metronome"
                        Foreground="#2E2E2E" Width="17" Height="17"
                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Nav: Tuner -->
                <Border Width="38" Height="38" CornerRadius="9"
                        Background="#111111" Margin="0,4"
                        BorderBrush="Transparent" BorderThickness="0.5"
                        Cursor="Hand">
                    <materialDesign:PackIcon Kind="Microphone"
                        Foreground="#2E2E2E" Width="17" Height="17"
                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Nav: Lessons -->
                <Border Width="38" Height="38" CornerRadius="9"
                        Background="#111111" Margin="0,4"
                        BorderBrush="Transparent" BorderThickness="0.5"
                        Cursor="Hand">
                    <materialDesign:PackIcon Kind="PlaylistMusic"
                        Foreground="#2E2E2E" Width="17" Height="17"
                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

            </StackPanel>
        </Border>

        <!-- Main -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Topbar -->
            <Grid Grid.Row="0" Margin="20,16,20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="ברוך הבא"
                               Foreground="#3A3A3A"
                               FontSize="10"
                               FontWeight="Bold"/>
                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="White">
                        <Run Text="שלום, "/>
                        <Run Text="יונתן" Foreground="#CC2200"/>
                    </TextBlock>
                </StackPanel>

                <!-- Notification bell -->
                <Border Grid.Column="1"
                        Width="30" Height="30" CornerRadius="8"
                        Background="#111111"
                        BorderBrush="#1A1A1A" BorderThickness="0.5">
                    <Grid>
                        <materialDesign:PackIcon Kind="Bell"
                            Foreground="#555555" Width="13" Height="13"
                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Ellipse Width="5" Height="5" Fill="#CC2200"
                                 HorizontalAlignment="Right" VerticalAlignment="Top"
                                 Margin="0,7,7,0"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Hero Banner -->
            <Border Grid.Row="1"
                    Margin="18,0,18,14"
                    CornerRadius="12"
                    Background="#0D0D0D"
                    BorderBrush="#1A1A1A"
                    BorderThickness="0.5"
                    Height="158"
                    ClipToBounds="True">
                <Grid>
                    <!-- Guitar silhouette (background art via Canvas) -->
                    <Canvas HorizontalAlignment="Right" Width="260" Height="158"
                            Opacity="1">
                    
                   
                      
                     
                    </Canvas>

                    <!-- Text content -->
                    <StackPanel Margin="22,20,0,0" VerticalAlignment="Top" HorizontalAlignment="Left">
                        <TextBlock Text="שיעור הבא"
                                   Foreground="#CC2200"
                                   FontSize="9"
                                   FontWeight="Bold"/>
                        <TextBlock Margin="0,5,0,14"
                                   FontSize="20" FontWeight="Black"
                                   LineHeight="24">
                            <Run Text="גיטרה " Foreground="White"/>
                            <Run Text="חשמלית" Foreground="#CC2200"/>
                            <LineBreak/>
                            <Run Text="מתקדמים" Foreground="White"/>
                        </TextBlock>
                        <Button Content="התחל שיעור"
                                Click="songsclick"
                                Background="#CC2200"
                                Foreground="White"
                                FontSize="11"
                                FontWeight="Bold"
                                Padding="14,7"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="7"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Section header: כלים -->
            <Grid Grid.Row="2" Margin="18,0,18,10">
                <TextBlock Text="כלים" Foreground="#888888"
                           FontSize="11" FontWeight="Bold"/>
                <TextBlock Text="הצג הכל" Foreground="#CC2200"
                           FontSize="11" HorizontalAlignment="Right"
                           Cursor="Hand"/>
            </Grid>

            <!-- 2x2 Cards Grid -->
            <UniformGrid Grid.Row="3" Rows="2" Columns="2" Margin="18,0,18,0">

                <!-- Songs -->
                <Border Margin="0,0,4,4" CornerRadius="11"
                        Background="#0D0D0D"
                        BorderBrush="#181818" BorderThickness="0.5">
                    <StackPanel Margin="14">
                        <Border Width="30" Height="30" CornerRadius="7"
                                Background="#140A0A"
                                BorderBrush="#22CC2200" BorderThickness="0.5"
                                HorizontalAlignment="Left" Margin="0,0,0,9">
                            <materialDesign:PackIcon Kind="MusicNote"
                                Foreground="#CC2200" Width="15" Height="15"
                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="שירים" Foreground="#CCCCCC" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="ספריית לימוד" Foreground="#383838" FontSize="10"/>
                    </StackPanel>
                </Border>

                <!-- Metronome -->
                <Border Margin="4,0,0,4" CornerRadius="11"
                        Background="#0D0D0D"
                        BorderBrush="#181818" BorderThickness="0.5">
                    
                    <StackPanel Margin="14" >
                        <Border Width="30" Height="30" CornerRadius="7"
                                Background="#140A0A"
                                BorderBrush="#22CC2200" BorderThickness="0.5"
                                HorizontalAlignment="Left" Margin="0,0,0,9">
                            <materialDesign:PackIcon Kind="Metronome"
                                Foreground="#CC2200" Width="15" Height="15"
                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="מטרונום" Foreground="#CCCCCC" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="כוונון קצב" Foreground="#383838" FontSize="10"/>
                    </StackPanel>
                </Border>

                <!-- Tuner -->
                <Border Margin="0,4,4,0" CornerRadius="11"
                        Background="#0D0D0D"
                        BorderBrush="#181818" BorderThickness="0.5">
                    <StackPanel Margin="14">
                        <Border Width="30" Height="30" CornerRadius="7"
                                Background="#140A0A"
                                BorderBrush="#22CC2200" BorderThickness="0.5"
                                HorizontalAlignment="Left" Margin="0,0,0,9">
                            <materialDesign:PackIcon Kind="Microphone"
                                Foreground="#CC2200" Width="15" Height="15"
                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="טיונר" Foreground="#CCCCCC" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="זיהוי צלילים" Foreground="#383838" FontSize="10"/>
                    </StackPanel>
                </Border>

                <!-- Lessons -->
                <Border Margin="4,4,0,0" CornerRadius="11"
                        Background="#0D0D0D"
                        BorderBrush="#181818" BorderThickness="0.5">
                    <StackPanel Margin="14">
                        <Border Width="30" Height="30" CornerRadius="7"
                                Background="#140A0A"
                                BorderBrush="#22CC2200" BorderThickness="0.5"
                                HorizontalAlignment="Left" Margin="0,0,0,9">
                            <materialDesign:PackIcon Kind="PlaylistMusic"
                                Foreground="#CC2200" Width="15" Height="15"
                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="ספריית האקורדים" Foreground="#CCCCCC" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="וידאו HD" Foreground="#383838" FontSize="10"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Divider -->
            <Rectangle Grid.Row="4" Height="1" Fill="#CC2200" Opacity="0.07"
                       Margin="18,14,18,14"/>

            <!-- Bottom stats strip -->
            <UniformGrid Grid.Row="5" Columns="3" Margin="18,0,18,18" VerticalAlignment="Top">

                <Border Margin="0,0,4,0" CornerRadius="10"
                        Background="#0D0D0D"
                        BorderBrush="#181818" BorderThickness="0.5">
                    <StackPanel Margin="13,11">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <Ellipse Width="6" Height="6" Fill="#CC2200" Opacity="0.8" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="BPM" Foreground="#555555" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="120" Foreground="White" FontSize="20" FontWeight="Black"/>
                        <TextBlock Text="מטרונום" Foreground="#333333" FontSize="9"/>
                    </StackPanel>
                </Border>

                <Border Margin="4,0,4,0" CornerRadius="10"
                        Background="#0D0D0D"
                        BorderBrush="#181818" BorderThickness="0.5">
                    <StackPanel Margin="13,11">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <Ellipse Width="6" Height="6" Fill="#CC2200" Opacity="0.8" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="צליל" Foreground="#555555" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="A3" Foreground="White" FontSize="20" FontWeight="Black"/>
                        <TextBlock Text="כוונן נוכחי" Foreground="#333333" FontSize="9"/>
                    </StackPanel>
                </Border>

                <Border Margin="4,0,0,0" CornerRadius="10"
                        Background="#0D0D0D"
                        BorderBrush="#181818" BorderThickness="0.5">
                    <StackPanel Margin="13,11">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <Ellipse Width="6" Height="6" Fill="#CC2200" Opacity="0.8" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="שיעורים" Foreground="#555555" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="12" Foreground="White" FontSize="20" FontWeight="Black"/>
                        <TextBlock Text="הושלמו" Foreground="#333333" FontSize="9"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

        </Grid>
    </Grid>

</Page>
