<Page x:Class="SignUpPage.xaml"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MusicSchoolWpf"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SignUpPage">

    <Grid>
       

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Grid.Column="1">

            <TextBlock Text="CREATE ACCOUNT"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0 0 0 30"
                       HorizontalAlignment="Center"               
                       />

            <TextBox x:Name="username"
                     Margin="0 0 0 15"
                     materialDesign:HintAssist.Hint="Username"
                     materialDesign:HintAssist.HelperText="Choose a username"
                     materialDesign:TextFieldAssist.HasClearButton="True"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />

            <TextBox x:Name="email"
                     Margin="0 0 0 15"
                     materialDesign:HintAssist.Hint="Email"
                     materialDesign:HintAssist.HelperText="Enter your email"
                     materialDesign:TextFieldAssist.HasClearButton="True"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />

            <PasswordBox x:Name="password"
                         Margin="0 0 0 15"
                         materialDesign:HintAssist.Hint="Password"
                         materialDesign:HintAssist.HelperText="Create a password"
                         Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}" />

            <PasswordBox x:Name="confirmPassword"
                         Margin="0 0 0 25"
                         materialDesign:HintAssist.Hint="Confirm Password"
                         materialDesign:HintAssist.HelperText="Repeat your password"
                         Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}" />

            <!--<Button x:Name="signup"
                    Content="SIGN UP"
                    Background="DarkRed"
                    Foreground="White"
                    Height="40"
                    Margin="0 0 0 15"-->
                    <!--Click="createaccount"/>-->

            <TextBlock Text="Already have an account?"
                       HorizontalAlignment="Center"/>

            <!--<Button Content="BACK TO LOGIN"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="DarkRed"
                    Click="GoToLogin"/>-->
        </StackPanel>
    </Grid>
</Page>
